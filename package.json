{
  "name": "bananadashboard",
  "version": "0.1.0",
  "description": "Desktop system dashboard by BananaBrother77",
  "main": "meow.js",
  "desktopName": "bananadashboard",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": {
    "name": "BananaBrother77",
    "email": "bananabrother77@online"
  },
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "online.bananabrother77.dashboard",
    "productName": "BananaDashboard",
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "syncDesktopName": true,
      "icon": "src/assets/icons/",
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "src/assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/assets/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "BananaBrother77",
        "repo": "BananaDashboard"
      }
    ],
    "files": [
      "meow.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "meow.js"
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
